				manager_comment as "Manager Approval Comment"
				submitted_at as "Submitted At"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (leave_type == "Annual")
				fields = [leave_type]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
